{% comment %} NALEA — On Sale Slider Section {% endcomment %}
{{ 'nalea-homepage.css' | asset_url | stylesheet_tag }}
{{ 'nalea-sections.css' | asset_url | stylesheet_tag }}

{% if section.settings.collection != blank %}
  {% assign col = collections[section.settings.collection] %}
{% endif %}

<div class="ns-sale-slider">
  <div class="ns-sale-slider__header">
    {% if section.settings.eyebrow != blank %}
      <p class="ns-sale-slider__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}
    <h2 class="ns-sale-slider__title">{{ section.settings.title | default: 'On Sale Now' }}</h2>
    {% if section.settings.subtitle != blank %}
      <p class="ns-sale-slider__sub">{{ section.settings.subtitle }}</p>
    {% endif %}
  </div>

  <div class="ns-sale-slider__track-wrap">
    <button class="ns-sale-slider__prev" aria-label="Previous">
      <svg width="18" height="18" viewBox="0 0 14 14" fill="none"><path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <button class="ns-sale-slider__next" aria-label="Next">
      <svg width="18" height="18" viewBox="0 0 14 14" fill="none"><path d="M5 2l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>

    <div class="ns-sale-slider__track">
      {% if col != blank %}
        {% for product in col.products limit: 20 %}
          {% assign discount = 0 %}
          {% if product.compare_at_price > product.price %}
            {% assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
          {% endif %}
          <div class="ns-sale-card">
            <a href="{{ product.url }}" class="ns-sale-card__media" aria-label="{{ product.title | escape }}">
              {% if product.featured_image != blank %}
                <img class="ns-sale-card__img"
                     src="{{ product.featured_image | image_url: width: 480 }}"
                     alt="{{ product.title | escape }}"
                     loading="lazy">
              {% endif %}
              {% if discount > 0 %}
                <span class="ns-sale-card__badge">-{{ discount }}%</span>
              {% elsif section.settings.sale_label != blank %}
                <span class="ns-sale-card__badge">{{ section.settings.sale_label }}</span>
              {% else %}
                <span class="ns-sale-card__badge">Sale</span>
              {% endif %}
            </a>
            <div class="ns-sale-card__info">
              <a href="{{ product.url }}" class="ns-sale-card__name">{{ product.title }}</a>
              <div class="ns-sale-card__prices">
                <span class="ns-sale-card__price">{{ product.price | money }}</span>
                {% if product.compare_at_price > product.price %}
                  <span class="ns-sale-card__compare">{{ product.compare_at_price | money }}</span>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      {% else %}
        <p style="color:rgba(232,217,181,.4);padding:40px 24px;">Select a collection in the theme editor.</p>
      {% endif %}
    </div>
  </div>

  <div class="ns-sale-slider__dots"></div>
</div>

<script src="{{ 'nalea-sections.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Sale Slider",
  "tag": "section",
  "class": "nalea-sale-slider-section",
  "settings": [
    { "type": "collection", "id": "collection",  "label": "Sale Collection" },
    { "type": "text",       "id": "eyebrow",     "label": "Eyebrow Text",   "default": "Limited Time" },
    { "type": "text",       "id": "title",       "label": "Heading",        "default": "On Sale Now" },
    { "type": "textarea",   "id": "subtitle",    "label": "Subtitle",       "default": "Up to 50% off — don't miss these deals." },
    { "type": "text",       "id": "sale_label",  "label": "Default Sale Badge", "default": "Sale" }
  ],
  "presets": [{ "name": "Sale Slider" }]
}
{% endschema %}
