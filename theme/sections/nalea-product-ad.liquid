{% comment %} NALEA — Product Ad Banner (left + right product) {% endcomment %}
{{ 'nalea-homepage.css' | asset_url | stylesheet_tag }}
{{ 'nalea-sections.css' | asset_url | stylesheet_tag }}

<div class="ns-product-ad">
  {% if section.settings.heading != blank %}
    <div class="ns-product-ad__header">
      <h2 class="ns-product-ad__title">{{ section.settings.heading }}</h2>
      {% if section.settings.sub != blank %}
        <p class="ns-product-ad__sub">{{ section.settings.sub }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="ns-product-ad__grid">

    <!-- LEFT AD (image top, info bottom) -->
    <div class="ns-ad-card ns-ad-card--left">
      <div class="ns-ad-card__media" style="height:320px;">
        {% if section.settings.left_image != blank %}
          <img class="ns-ad-card__img"
               src="{{ section.settings.left_image | image_url: width: 800 }}"
               alt="{{ section.settings.left_name | escape }}"
               loading="lazy">
        {% else %}
          <div style="width:100%;height:100%;background:linear-gradient(135deg,#1a0a1e,#0e0a1a);"></div>
        {% endif %}
        <div class="ns-ad-card__media-overlay"></div>
        {% if section.settings.left_tag != blank %}
          <span class="ns-ad-card__tag">{{ section.settings.left_tag }}</span>
        {% else %}
          <span class="ns-ad-card__tag">New In</span>
        {% endif %}
      </div>
      <div class="ns-ad-card__body">
        {% if section.settings.left_eyebrow != blank %}
          <p class="ns-ad-card__eyebrow">{{ section.settings.left_eyebrow }}</p>
        {% endif %}
        <h3 class="ns-ad-card__name">{{ section.settings.left_name | default: 'Featured Style' }}</h3>
        {% if section.settings.left_desc != blank %}
          <p class="ns-ad-card__desc">{{ section.settings.left_desc }}</p>
        {% endif %}
        <div class="ns-ad-card__prices">
          {% if section.settings.left_price != blank %}
            <span class="ns-ad-card__price">{{ section.settings.left_price }}</span>
          {% endif %}
          {% if section.settings.left_compare != blank %}
            <span class="ns-ad-card__compare">{{ section.settings.left_compare }}</span>
          {% endif %}
        </div>
        {% if section.settings.left_url != blank %}
          <a href="{{ section.settings.left_url }}" class="ns-ad-card__cta">
            Shop Now
            <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        {% endif %}
      </div>
    </div>

    <!-- RIGHT AD (split: image left, info right) -->
    <div class="ns-ad-card ns-ad-card--right">
      <div class="ns-ad-card__media">
        {% if section.settings.right_image != blank %}
          <img class="ns-ad-card__img"
               src="{{ section.settings.right_image | image_url: width: 800 }}"
               alt="{{ section.settings.right_name | escape }}"
               loading="lazy">
        {% else %}
          <div style="width:100%;height:100%;background:linear-gradient(135deg,#100a00,#1e1400);"></div>
        {% endif %}
        <div class="ns-ad-card__media-overlay"></div>
        {% if section.settings.right_tag != blank %}
          <span class="ns-ad-card__tag">{{ section.settings.right_tag }}</span>
        {% else %}
          <span class="ns-ad-card__tag">Best Seller</span>
        {% endif %}
      </div>
      <div class="ns-ad-card__body">
        {% if section.settings.right_eyebrow != blank %}
          <p class="ns-ad-card__eyebrow">{{ section.settings.right_eyebrow }}</p>
        {% endif %}
        <h3 class="ns-ad-card__name">{{ section.settings.right_name | default: 'Trending Now' }}</h3>
        {% if section.settings.right_desc != blank %}
          <p class="ns-ad-card__desc">{{ section.settings.right_desc }}</p>
        {% endif %}
        <div class="ns-ad-card__prices">
          {% if section.settings.right_price != blank %}
            <span class="ns-ad-card__price">{{ section.settings.right_price }}</span>
          {% endif %}
          {% if section.settings.right_compare != blank %}
            <span class="ns-ad-card__compare">{{ section.settings.right_compare }}</span>
          {% endif %}
        </div>
        {% if section.settings.right_url != blank %}
          <a href="{{ section.settings.right_url }}" class="ns-ad-card__cta">
            Shop Now
            <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        {% endif %}
      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Product Ad Banner",
  "tag": "section",
  "class": "nalea-product-ad-section",
  "settings": [
    { "type": "text",     "id": "heading", "label": "Section Heading", "default": "Featured Drops" },
    { "type": "textarea", "id": "sub",     "label": "Subtext" },
    { "type": "header",   "content": "Left Product Ad" },
    { "type": "image_picker", "id": "left_image",   "label": "Image" },
    { "type": "text",         "id": "left_tag",     "label": "Badge Tag",   "default": "New In" },
    { "type": "text",         "id": "left_eyebrow", "label": "Eyebrow",     "default": "Just Landed" },
    { "type": "text",         "id": "left_name",    "label": "Product Name","default": "Midnight Luxe Set" },
    { "type": "textarea",     "id": "left_desc",    "label": "Description", "default": "Where elegance meets the night. A statement piece for every occasion." },
    { "type": "text",         "id": "left_price",   "label": "Price",       "default": "R 850" },
    { "type": "text",         "id": "left_compare", "label": "Compare Price","default": "R 1 200" },
    { "type": "url",          "id": "left_url",     "label": "Shop Link" },
    { "type": "header",   "content": "Right Product Ad" },
    { "type": "image_picker", "id": "right_image",   "label": "Image" },
    { "type": "text",         "id": "right_tag",     "label": "Badge Tag",   "default": "Best Seller" },
    { "type": "text",         "id": "right_eyebrow", "label": "Eyebrow",     "default": "Trending Now" },
    { "type": "text",         "id": "right_name",    "label": "Product Name","default": "Gold Hour Dress" },
    { "type": "textarea",     "id": "right_desc",    "label": "Description", "default": "The dress that stops rooms. Crafted for the bold, designed for the beautiful." },
    { "type": "text",         "id": "right_price",   "label": "Price",       "default": "R 720" },
    { "type": "text",         "id": "right_compare", "label": "Compare Price","default": "R 990" },
    { "type": "url",          "id": "right_url",     "label": "Shop Link" }
  ],
  "presets": [{ "name": "Product Ad Banner" }]
}
{% endschema %}
