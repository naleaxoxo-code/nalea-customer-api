{% comment %} NALEA — View All Products Burning Glass Bar {% endcomment %}
{{ 'nalea-homepage.css' | asset_url | stylesheet_tag }}
{{ 'nalea-sections.css' | asset_url | stylesheet_tag }}

<div class="ns-view-all-bar">

  <a href="{{ section.settings.url | default: '/collections/all' }}" class="ns-burn-bar">
    <!-- Sparks at corners -->
    <div class="ns-burn-bar__sparks">
      <div class="ns-spark ns-spark--tl"></div>
      <div class="ns-spark ns-spark--tr"></div>
      <div class="ns-spark ns-spark--bl"></div>
      <div class="ns-spark ns-spark--br"></div>
      <div class="ns-spark ns-spark--ml"></div>
      <div class="ns-spark ns-spark--mr"></div>
    </div>

    <!-- Fire icon -->
    <div class="ns-burn-bar__icon" aria-hidden="true">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2C9 7 5 9 5 14a7 7 0 0014 0c0-5-4-7-7-12zm0 18c-2.2 0-4-1.8-4-4 0-2.5 2-4.5 4-7 2 2.5 4 4.5 4 7 0 2.2-1.8 4-4 4z"/>
      </svg>
    </div>

    <!-- Text -->
    <div class="ns-burn-bar__text">
      <span class="ns-burn-bar__title">{{ section.settings.label | default: 'View All Products' }}</span>
      {% if section.settings.sub != blank %}
        <span class="ns-burn-bar__sub">{{ section.settings.sub }}</span>
      {% endif %}
    </div>

    <!-- Arrow -->
    <div class="ns-burn-bar__arrow" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14M13 6l6 6-6 6"/>
      </svg>
    </div>
  </a>

  <!-- Stats strip -->
  {% if section.settings.stat1 != blank or section.settings.stat2 != blank or section.settings.stat3 != blank %}
    <div class="ns-view-all-bar__stats">
      {% if section.settings.stat1 != blank %}
        <div class="ns-view-all-bar__stat">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><polygon points="12,2 22,9 18,21 6,21 2,9"/><line x1="2" y1="9" x2="22" y2="9"/></svg>
          <span>{{ section.settings.stat1 }}</span>
        </div>
      {% endif %}
      {% if section.settings.stat2 != blank %}
        <div class="ns-view-all-bar__stat">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="3" y="3" width="8" height="8" rx="1"/><rect x="13" y="3" width="8" height="8" rx="1"/><rect x="3" y="13" width="8" height="8" rx="1"/><rect x="13" y="13" width="8" height="8" rx="1"/></svg>
          <span>{{ section.settings.stat2 }}</span>
        </div>
      {% endif %}
      {% if section.settings.stat3 != blank %}
        <div class="ns-view-all-bar__stat">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M12 2v20M2 12h20"/></svg>
          <span>{{ section.settings.stat3 }}</span>
        </div>
      {% endif %}
    </div>
  {% endif %}

</div>

<script src="{{ 'nalea-sections.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "View All Bar",
  "tag": "section",
  "class": "nalea-view-all-bar-section",
  "settings": [
    { "type": "text",     "id": "label", "label": "Button Label",  "default": "View All Products" },
    { "type": "text",     "id": "sub",   "label": "Subtitle",      "default": "Explore the full NALEA collection" },
    { "type": "url",      "id": "url",   "label": "Destination Link" },
    { "type": "header",   "content": "Stats Strip" },
    { "type": "text",     "id": "stat1", "label": "Stat 1", "default": "200+ Styles" },
    { "type": "text",     "id": "stat2", "label": "Stat 2", "default": "20 Departments" },
    { "type": "text",     "id": "stat3", "label": "Stat 3", "default": "New Arrivals Weekly" }
  ],
  "presets": [{ "name": "View All Bar" }]
}
{% endschema %}
